{
  "version": "0.1.8",
  "keywords": [
    "strapi",
    "plugin",
    "markdown",
    "editor",
    "codemirror"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "@rootflow/mdeditor": "^0.2.4"
  },
  "devDependencies": {
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/sdk-plugin": "^6.0.1",
    "@strapi/strapi": "^5.38.0",
    "@strapi/typescript-utils": "^5.38.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/sdk-plugin": "^6.0.1",
    "@strapi/strapi": "^5.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.11"
  },
  "strapi": {
    "kind": "plugin",
    "name": "mdeditor-strapi",
    "displayName": "RF MDEditor",
    "description": "Strapi plugin for Markdown Editor"
  },
  "name": "@rootflow/mdeditor-strapi",
  "description": "Strapi plugin for Markdown Editor",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/avainroot/mdeditor-strapi.git"
  },
  "bugs": {
    "url": "https://github.com/avainroot/mdeditor-strapi/issues"
  },
  "homepage": "https://github.com/avainroot/mdeditor-strapi#readme",
  "author": "Ava <ava.inroot@gmail.com>"
}
